# ── LLM Provider ───────────────────────────────────────────────────────────────
LLM_PROVIDER=openai              # openai | anthropic | google
LLM_MODEL=gpt-4o

OPENAI_API_KEY=sk-...            # înlocuiește cu cheia reală
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...             # doar pentru AI Studio; preferă Vertex AI

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400          # 24 ore

# ── Pipeline / Cost Control ───────────────────────────────────────────────────
PIPELINE_MAX_CONCURRENCY=5
MAX_CHUNK_TOKENS=2048
INCLUDE_SOURCE_BY_DEFAULT=false

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=1000000         # 1 MB

# ── Prefilter (Elasticsearch-like candidate selection) ───────────────────────
PREFILTER_UPLOAD_ENABLED=true
PREFILTER_JSON_ENABLED=false
PREFILTER_MAX_CHUNKS=8
PREFILTER_MIN_SCORE=0.15

# ── Rate limit ────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# ── Knowledge Graph Memory ───────────────────────────────────────────────────
KNOWLEDGE_GRAPH_ENABLED=true
KNOWLEDGE_GRAPH_STORE_PATH=data/knowledge_graph.json
KNOWLEDGE_GRAPH_MAX_NODES=10000
KNOWLEDGE_GRAPH_CONTEXT_ITEMS=3

# ── PostgreSQL (opțional) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/code_analyzer

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
