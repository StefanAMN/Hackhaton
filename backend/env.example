# ── LLM Provider ───────────────────────────────────────────────────────────────
LLM_PROVIDER=openai              # openai | anthropic | google
LLM_MODEL=gpt-4o

OPENAI_API_KEY=sk-...            # înlocuiește cu cheia reală
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...             # doar pentru AI Studio; preferă Vertex AI

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400          # 24 ore

# ── PostgreSQL (opțional) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/code_analyzer

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
